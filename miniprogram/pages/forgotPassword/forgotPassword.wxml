<!-- 忘记密码页面 - Vibrant Wellness -->
<view class="page-bg">
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <view class="page-content">
    <view class="top-nav">
      <view class="nav-back-btn" bindtap="onBack">
        <text class="back-arrow">←</text>
      </view>
      <text class="nav-title-text">重置密码</text>
      <view class="nav-spacer"></view>
    </view>

    <view class="form-card animate-slide-up">
      <text class="form-title">忘记密码？</text>
      <text class="form-subtitle">验证手机号后即可重置</text>

      <!-- 手机号 -->
      <view class="input-group">
        <view class="input-wrapper">
          <text class="input-icon-left">📱</text>
          <input
            class="input-field input-has-icon"
            type="text"
            maxlength="11"
            placeholder="请输入注册手机号"
            placeholder-class="input-placeholder"
            value="{{phone}}"
            bindinput="onPhoneInput"
          />
        </view>
      </view>

      <!-- 验证码 -->
      <view class="input-group">
        <view class="code-row">
          <view class="input-wrapper" style="flex:1">
            <text class="input-icon-left">📨</text>
            <input
              class="input-field input-has-icon"
              type="text"
              maxlength="6"
              placeholder="验证码"
              placeholder-class="input-placeholder"
              value="{{code}}"
              bindinput="onCodeInput"
            />
          </view>
          <button
            class="code-btn {{countdown > 0 ? 'code-btn-disabled' : ''}}"
            bindtap="sendCode"
            disabled="{{countdown > 0}}"
          >
            {{countdown > 0 ? countdown + 's后重发' : '获取验证码'}}
          </button>
        </view>
      </view>

      <!-- 新密码 -->
      <view class="input-group">
        <view class="input-wrapper">
          <text class="input-icon-left">🔒</text>
          <input
            class="input-field input-has-icon input-has-right"
            password="{{!showPassword}}"
            maxlength="20"
            placeholder="请输入新密码（至少6位）"
            placeholder-class="input-placeholder"
            value="{{newPassword}}"
            bindinput="onNewPasswordInput"
          />
          <view class="pwd-toggle" bindtap="togglePassword">
            <text>{{showPassword ? '🙈' : '👁️'}}</text>
          </view>
        </view>
      </view>

      <button class="btn btn-accent btn-lg reset-btn" bindtap="onReset" loading="{{loading}}">
        重置密码
      </button>
    </view>
  </view>
</view>
