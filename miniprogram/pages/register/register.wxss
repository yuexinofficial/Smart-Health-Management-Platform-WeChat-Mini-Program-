/* 注册页样式 */
.page-bg {
  min-height: 100vh;
  background: linear-gradient(160deg, #ECFEFF 0%, #F0FDF4 50%, #FFF7ED 100%);
  position: relative;
  overflow: hidden;
}

.bg-decoration { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; overflow: hidden; }
.bg-circle { position: absolute; border-radius: 50%; opacity: 0.12; }
.bg-circle-1 { width: 400rpx; height: 400rpx; background: #0EA5B9; top: -100rpx; right: -100rpx; }
.bg-circle-2 { width: 300rpx; height: 300rpx; background: #10B981; bottom: -50rpx; left: -80rpx; }

.page-content { padding: 0 48rpx; position: relative; z-index: 1; }

.top-nav { display: flex; align-items: center; padding: 20rpx 0 40rpx; }
.nav-back-btn { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: center; }
.back-arrow { font-size: 36rpx; color: #1E293B; font-weight: 600; }
.nav-title-text { flex: 1; text-align: center; font-size: 34rpx; font-weight: 700; color: #1E293B; }
.nav-spacer { width: 64rpx; }

.form-card { background: #FFFFFF; border-radius: 32rpx; padding: 48rpx 36rpx; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.06); }

.form-title { font-size: 40rpx; font-weight: 800; color: #0D9488; display: block; margin-bottom: 8rpx; }
.form-subtitle { font-size: 26rpx; color: #94A3B8; display: block; margin-bottom: 40rpx; }

.input-group { margin-bottom: 24rpx; }
.input-wrapper { position: relative; display: flex; align-items: center; }
.input-icon-left { position: absolute; left: 28rpx; font-size: 32rpx; z-index: 2; }
.input-field { width: 100%; height: 96rpx; background: #F8FAFC; border-radius: 20rpx; font-size: 30rpx; box-sizing: border-box; border: 2rpx solid #E2E8F0; color: #1E293B; }
.input-has-icon { padding-left: 72rpx; }
.input-has-right { padding-right: 80rpx; }
.input-field:focus { border-color: #0EA5B9; background: #FFF; box-shadow: 0 0 0 8rpx rgba(14,165,185,0.06); }
.input-placeholder { color: #94A3B8; }

.pwd-toggle { position: absolute; right: 28rpx; font-size: 32rpx; z-index: 2; padding: 8rpx; }

.error-tip { font-size: 24rpx; color: #EF4444; margin-top: 8rpx; display: block; padding-left: 8rpx; }

.register-btn { width: 100%; margin-top: 16rpx; }

.login-link { text-align: center; margin-top: 32rpx; font-size: 26rpx; color: #94A3B8; }
.link-text { color: #0EA5B9; font-weight: 600; margin-left: 8rpx; }
