/* 登录页样式 - Vibrant Wellness 微信快捷登录版 */

.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #ECFEFF 0%, #E0F7FA 30%, #F0FDF4 70%, #FFF7ED 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 背景装饰圆 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
}

.bg-circle-1 {
  width: 560rpx;
  height: 560rpx;
  background: #0EA5B9;
  top: -200rpx;
  right: -140rpx;
}

.bg-circle-2 {
  width: 360rpx;
  height: 360rpx;
  background: #10B981;
  bottom: -120rpx;
  left: -100rpx;
}

.login-content {
  width: 100%;
  padding: 40rpx 48rpx 60rpx;
  position: relative;
  z-index: 1;
}

/* Logo品牌区 */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  background: #FFFFFF;
  box-shadow: 0 16rpx 48rpx rgba(14, 165, 185, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo {
  width: 88rpx;
  height: 88rpx;
}

.brand-name {
  font-size: 42rpx;
  font-weight: 800;
  color: #0D9488;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}

.brand-slogan {
  font-size: 24rpx;
  color: #64748B;
  letter-spacing: 2rpx;
}

/* 微信快捷登录 */
.wechat-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 50rpx;
  border: none;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.35);
  transition: all 0.2s;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.wechat-login-btn[loading] {
  opacity: 0.7;
}

.wechat-icon {
  font-size: 40rpx;
}

.wechat-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

/* 分隔线 */
.divider-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #CBD5E1;
}

.divider-text {
  font-size: 24rpx;
  color: #94A3B8;
  white-space: nowrap;
}

/* 手机号表单 */
.form-area {
  margin-bottom: 36rpx;
}

.input-group {
  margin-bottom: 20rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-icon-left {
  position: absolute;
  left: 28rpx;
  font-size: 34rpx;
  z-index: 2;
}

.input-field {
  width: 100%;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid #E2E8F0;
  color: #1E293B;
  transition: all 0.2s;
}

.input-has-icon {
  padding-left: 72rpx;
}

.input-has-right {
  padding-right: 80rpx;
}

.input-field:focus {
  border-color: #0EA5B9;
  box-shadow: 0 0 0 8rpx rgba(14, 165, 185, 0.08);
}

.input-placeholder {
  color: #94A3B8;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  font-size: 34rpx;
  z-index: 2;
  padding: 10rpx;
}

.login-btn {
  width: 100%;
  margin-top: 12rpx;
}

/* 底部链接 */
.bottom-links {
  display: flex;
  justify-content: center;
  align-items: center;
}

.link-item {
  font-size: 26rpx;
  color: #0EA5B9;
  padding: 12rpx 24rpx;
  font-weight: 500;
}

.link-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #CBD5E1;
}
