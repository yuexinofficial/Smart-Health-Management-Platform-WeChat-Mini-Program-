/* 关于我们样式 */
.about-page { min-height: 100vh; background: #F8FAFC; padding: 24rpx; }

.nav-header { display: flex; align-items: center; padding: 16rpx 0 24rpx; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #F8FAFC; }
.back-icon { font-size: 36rpx; color: #1E293B; font-weight: 600; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 700; color: #1E293B; }
.nav-placeholder { width: 60rpx; }

.hero-area { display: flex; flex-direction: column; align-items: center; padding: 48rpx 0; }
.hero-logo { width: 120rpx; height: 120rpx; border-radius: 32rpx; background: #E0F7FA; margin-bottom: 20rpx; }
.hero-name { font-size: 36rpx; font-weight: 800; color: #0D9488; margin-bottom: 8rpx; }
.hero-ver { font-size: 24rpx; color: #94A3B8; }

.info-card { background: #FFF; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }

.info-block { margin-bottom: 12rpx; }
.info-label { font-size: 30rpx; font-weight: 700; color: #1E293B; display: block; margin-bottom: 14rpx; }
.info-text { font-size: 26rpx; color: #64748B; line-height: 1.9; display: block; }

.feature-list { display: flex; flex-direction: column; gap: 12rpx; }
.feature-item { font-size: 26rpx; color: #475569; padding: 14rpx 20rpx; background: #F8FAFC; border-radius: 12rpx; }

.tech-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tech-item { width: calc(50% - 8rpx); background: #F8FAFC; border-radius: 14rpx; padding: 20rpx; display: flex; flex-direction: column; }
.tech-name { font-size: 22rpx; color: #94A3B8; margin-bottom: 6rpx; }
.tech-val { font-size: 26rpx; color: #1E293B; font-weight: 600; }

.divider { height: 1rpx; background: #F1F5F9; margin: 24rpx 0; }

.footer-text { text-align: center; padding: 40rpx; font-size: 24rpx; color: #CBD5E1; }
