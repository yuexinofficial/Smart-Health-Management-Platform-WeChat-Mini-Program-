/* 个人中心样式 */
.profile-page { min-height: 100vh; background: #F8FAFC; }

.profile-header {
  background: linear-gradient(160deg, #0D9488 0%, #0EA5B9 50%, #06B6D4 100%);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute; top: -60rpx; right: -40rpx;
  width: 240rpx; height: 240rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.profile-avatar-wrap { position: relative; margin-bottom: 20rpx; z-index: 1; }
.profile-avatar { width: 140rpx; height: 140rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.5); background: rgba(255,255,255,0.2); }
.avatar-badge {
  position: absolute; bottom: 4rpx; right: 4rpx;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: #FFF; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.profile-name { font-size: 36rpx; font-weight: 700; color: #FFF; margin-bottom: 6rpx; z-index: 1; }
.profile-phone { font-size: 24rpx; color: rgba(255,255,255,0.75); margin-bottom: 16rpx; z-index: 1; }
.profile-tags { display: flex; gap: 16rpx; z-index: 1; }
.profile-tag { font-size: 22rpx; color: #FFF; background: rgba(255,255,255,0.2); padding: 6rpx 20rpx; border-radius: 20rpx; }

.menu-section { padding: 24rpx; }
.menu-group { background: #FFF; border-radius: 24rpx; overflow: hidden; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }

.menu-item {
  display: flex; align-items: center; padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F1F5F9;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #F8FAFC; }

.menu-icon-wrap { width: 64rpx; height: 64rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; }
.menu-emoji { font-size: 32rpx; }
.menu-label { flex: 1; font-size: 30rpx; color: #1E293B; font-weight: 500; }
.menu-arrow { font-size: 40rpx; color: #CBD5E1; font-weight: 300; }

.logout-area { padding: 40rpx 24rpx; }
.logout-btn {
  width: 100%; height: 92rpx; background: #FFF; color: #EF4444;
  border-radius: 24rpx; font-size: 30rpx; font-weight: 600;
  border: 2rpx solid #FEE2E2; display: flex; align-items: center; justify-content: center;
}
.logout-btn::after { border: none; }
.logout-btn:active { background: #FEF2F2; }
