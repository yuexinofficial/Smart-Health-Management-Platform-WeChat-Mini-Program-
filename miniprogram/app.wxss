/* ========================================
   运动健康管理 - 全局设计系统
   Vibrant Wellness Aesthetic
   ======================================== */

/* CSS 变量 - 使用 WeChat 兼容方式 */
page {
  /* 主色调 - 活力青绿 */
  --primary: #0EA5B9;
  --primary-dark: #0D9488;
  --primary-light: #E0F7FA;
  --primary-gradient: linear-gradient(135deg, #0EA5B9, #06B6D4);

  /* 强调色 - 能量橙 */
  --accent: #F97316;
  --accent-light: #FFF7ED;
  --accent-gradient: linear-gradient(135deg, #F97316, #FB923C);

  /* 功能色 */
  --success: #10B981;
  --success-light: #ECFDF5;
  --danger: #EF4444;
  --danger-light: #FEF2F2;
  --warning: #F59E0B;
  --warning-light: #FFFBEB;

  /* 背景 */
  --bg: #F8FAFC;
  --bg-warm: #F7F4F0;
  --card-bg: #FFFFFF;

  /* 文字 */
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-muted: #94A3B8;
  --text-inverse: #FFFFFF;

  /* 边框与阴影 */
  --border: #E2E8F0;
  --shadow-sm: 0 2rpx 12rpx rgba(0,0,0,0.04);
  --shadow-md: 0 8rpx 32rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 16rpx 48rpx rgba(0,0,0,0.12);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-full: 9999rpx;

  /* 基础样式 */
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ========================================
   通用容器
   ======================================== */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ========================================
   卡片系统
   ======================================== */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s, box-shadow 0.2s;
}

.card-elevated {
  box-shadow: var(--shadow-md);
}

.card-glass {
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* ========================================
   按钮系统
   ======================================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.2s;
  letter-spacing: 2rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(14, 165, 185, 0.3);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-accent {
  background: var(--accent-gradient);
  color: var(--text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.3);
}

.btn-accent:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-success {
  background: var(--success);
  color: var(--text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.btn-danger {
  background: var(--danger);
  color: var(--text-inverse);
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.25);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}

.btn-ghost:active {
  background: var(--bg);
}

.btn-sm {
  height: 64rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  border-radius: var(--radius-full);
}

.btn-lg {
  height: 100rpx;
  font-size: 34rpx;
}

button[disabled] {
  opacity: 0.5;
}

/* ========================================
   输入框系统
   ======================================== */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  display: block;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 92rpx;
  background: var(--bg);
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  color: var(--text-primary);
}

.input-field:focus {
  border-color: var(--primary);
  background: var(--card-bg);
  box-shadow: 0 0 0 6rpx rgba(14, 165, 185, 0.1);
}

.input-field-password {
  padding-right: 80rpx;
}

.input-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: var(--text-muted);
  z-index: 2;
}

.input-wrapper {
  position: relative;
}

/* ========================================
   导航栏
   ======================================== */
.nav-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--bg);
}

.nav-back:active {
  background: var(--border);
}

.back-icon {
  font-size: 36rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 64rpx;
}

.nav-placeholder {
  width: 64rpx;
}

/* ========================================
   布局辅助
   ======================================== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

.gap-sm { gap: 12rpx; }
.gap-md { gap: 20rpx; }
.gap-lg { gap: 32rpx; }

/* ========================================
   空状态
   ======================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  text-align: center;
}

/* ========================================
   标签系统
   ======================================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.tag-accent {
  background: var(--accent-light);
  color: var(--accent);
}

.tag-success {
  background: var(--success-light);
  color: var(--success);
}

.tag-danger {
  background: var(--danger-light);
  color: var(--danger);
}

.tag-warning {
  background: var(--warning-light);
  color: var(--warning);
}

/* ========================================
   分割线
   ======================================== */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* ========================================
   安全区域底部
   ======================================== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========================================
   动画
   ======================================== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes shimmer {
  0% { background-position: -400rpx 0; }
  100% { background-position: 400rpx 0; }
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out;
}

.animate-slide-up {
  animation: slideUp 0.5s ease-out;
}

/* stagger children */
.stagger-item:nth-child(1) { animation-delay: 0s; }
.stagger-item:nth-child(2) { animation-delay: 0.08s; }
.stagger-item:nth-child(3) { animation-delay: 0.16s; }
.stagger-item:nth-child(4) { animation-delay: 0.24s; }
.stagger-item:nth-child(5) { animation-delay: 0.32s; }
.stagger-item:nth-child(6) { animation-delay: 0.40s; }
.stagger-item:nth-child(7) { animation-delay: 0.48s; }
.stagger-item:nth-child(8) { animation-delay: 0.56s; }

/* ========================================
   加载骨架屏
   ======================================== */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 800rpx 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}
