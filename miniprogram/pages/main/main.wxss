/* 主页样式 - Vibrant Wellness */

.home-page {
  min-height: 100vh;
  background: #F8FAFC;
}

/* 顶部渐变头部 */
.home-header {
  background: linear-gradient(160deg, #0EA5B9 0%, #06B6D4 40%, #10B981 100%);
  padding: 40rpx 32rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.home-header::after {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.greeting-area {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.greeting-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.header-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.5);
  overflow: hidden;
}

.avatar-sm {
  width: 72rpx;
  height: 72rpx;
}

/* 步数英雄区 */
.steps-hero {
  display: flex;
  align-items: center;
  gap: 32rpx;
  position: relative;
  z-index: 1;
}

.steps-ring {
  flex-shrink: 0;
}

.ring-outer {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-inner {
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.steps-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #0D9488;
  line-height: 1.1;
}

.steps-unit {
  font-size: 22rpx;
  color: #64748B;
}

.steps-info {
  display: flex;
  flex-direction: column;
}

.steps-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.steps-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

/* 快捷卡片 */
.quick-cards {
  padding: 0 24rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
}

.quick-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
}

.motivation-quick {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.quick-card-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.quick-card-content {
  flex: 1;
  min-width: 0;
}

.quick-card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #F97316;
  display: block;
  margin-bottom: 6rpx;
}

.quick-card-text {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 天气快捷卡片 */
.weather-quick {
  background: linear-gradient(135deg, #E0F7FA, #FFFFFF);
}

.weather-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.weather-temp {
  font-size: 48rpx;
  font-weight: 800;
  color: #0D9488;
}

.weather-text {
  font-size: 28rpx;
  color: #64748B;
}

.weather-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #94A3B8;
  flex-wrap: wrap;
}

.weather-loc {
  color: #334155;
  font-weight: 500;
}

/* 功能区域 */
.section {
  padding: 0 24rpx;
  margin-top: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 20rpx;
  display: block;
  padding-left: 8rpx;
}

.func-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.func-card {
  width: calc(25% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 0 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}

.func-card:active {
  transform: scale(0.95);
}

.func-icon-bg {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.func-emoji {
  font-size: 40rpx;
}

.func-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 4rpx;
}

.func-desc {
  font-size: 20rpx;
  color: #94A3B8;
}
