/* 健康建议样式 */
.advice-page { min-height: 100vh; background: #F8FAFC; padding: 24rpx; }

.nav-header { display: flex; align-items: center; padding: 16rpx 0 24rpx; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #F8FAFC; }
.back-icon { font-size: 36rpx; color: #1E293B; font-weight: 600; }
.nav-title { flex: 1; text-align: center; font-size: 34rpx; font-weight: 700; color: #1E293B; }
.nav-placeholder { width: 60rpx; }

/* 双按钮 */
.btn-duo { display: flex; gap: 20rpx; margin-bottom: 24rpx; }
.duo-btn {
  flex: 1; background: #FFF; border-radius: 24rpx; padding: 36rpx 24rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); position: relative;
  transition: transform 0.15s;
}
.duo-btn:active { transform: scale(0.96); }
.duo-icon { font-size: 52rpx; margin-bottom: 12rpx; }
.duo-label { font-size: 28rpx; font-weight: 700; color: #1E293B; margin-bottom: 4rpx; }
.duo-desc { font-size: 22rpx; color: #94A3B8; }

.loading-dots { display: flex; gap: 8rpx; margin-top: 12rpx; }
.dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #CBD5E1; animation: bounce 1.4s ease-in-out infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 加载卡片 */
.loading-card {
  background: #FFF; border-radius: 24rpx; padding: 72rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.spinner {
  width: 60rpx; height: 60rpx; border: 4rpx solid #E2E8F0;
  border-top-color: #0EA5B9; border-radius: 50%;
  animation: spin 0.8s linear infinite; margin-bottom: 24rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-msg { font-size: 30rpx; color: #334155; font-weight: 600; margin-bottom: 8rpx; }
.loading-sub { font-size: 24rpx; color: #94A3B8; }

/* 结果卡片 */
.result-card { background: #FFF; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }
.result-head { display: flex; align-items: center; margin-bottom: 24rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid #F1F5F9; }
.result-icon { font-size: 40rpx; margin-right: 12rpx; }
.result-label { font-size: 32rpx; font-weight: 700; color: #1E293B; }
.result-body { }
.result-text { font-size: 28rpx; color: #475569; line-height: 2; white-space: pre-wrap; }

/* 初始状态 */
.init-card {
  background: #FFF; border-radius: 24rpx; padding: 60rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.init-emoji { font-size: 80rpx; margin-bottom: 20rpx; }
.init-title { font-size: 34rpx; font-weight: 700; color: #1E293B; margin-bottom: 16rpx; }
.init-desc { font-size: 26rpx; color: #64748B; text-align: center; line-height: 1.8; margin-bottom: 32rpx; }
.init-features { display: flex; flex-direction: column; gap: 16rpx; width: 100%; }
.feat { font-size: 26rpx; color: #475569; padding: 16rpx 24rpx; background: #F8FAFC; border-radius: 14rpx; text-align: center; }
